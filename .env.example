# ===== Telegram bot =====
# Token issued by @BotFather
BOT_TOKEN=your_bot_token_here
# Comma-separated Telegram user IDs allowed to use the bot.
# Leave empty to allow everyone (not recommended).
ADMIN_IDS=

# ===== WireGuard container access =====
# Name of the WireGuard container (must match docker-compose service name / container_name)
WG_CONTAINER_NAME=wireguard
WG_INTERFACE=wg0

# ===== WireGuard server parameters =====
# Public endpoint that clients will connect to (domain or IP).
# Port part MUST match WG_SERVER_PORT.
WG_SERVER_ENDPOINT=vpn.example.com:51820
WG_SERVER_PORT=51820

# Subnet for VPN peers. /22 gives 1024 addresses (~1021 usable for clients).
WG_NETWORK=10.0.0.0/22
WG_SERVER_IP=10.0.0.1

# Hard cap on number of peers.
WG_MAX_PEERS=1000

# Host outbound interface used in MASQUERADE rule inside the WG container.
WG_EGRESS_IFACE=eth0

# DNS pushed to clients in their .conf files.
WG_DNS=1.1.1.1

# ===== Database =====
# Path inside the bot container.
DB_PATH=/data/vpn.db
